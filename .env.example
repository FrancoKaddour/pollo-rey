# ─── BASE DE DATOS ────────────────────────────────
# Desarrollo local: SQLite (no requiere configuración)
DATABASE_URL="file:./dev.db"

# Producción: Vercel Postgres (reemplazar al deployar)
# DATABASE_URL="postgresql://..."

# ─── NEXTAUTH ─────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secret-aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─── WHATSAPP BUSINESS ────────────────────────────
# Número sin + ni espacios. Ej: 5491112345678
NEXT_PUBLIC_WHATSAPP_PHONE="549XXXXXXXXXX"

# ─── EMAIL (Newsletter y notificaciones) ──────────
RESEND_API_KEY="re_..."
NEXT_PUBLIC_EMAIL_FROM="hola@pollorey.com.ar"

# ─── ALMACENAMIENTO DE IMÁGENES ───────────────────
# Vercel Blob (obtener en vercel.com/storage)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# ─── ANALYTICS (opcional) ─────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
